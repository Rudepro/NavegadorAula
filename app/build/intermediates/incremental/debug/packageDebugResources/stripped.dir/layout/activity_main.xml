<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout principal de NavegadorAula — versión con Historial + UI mejorada.
    Arquitectura visual:
    ┌─────────────────────────────────────┐
    │          Panel superior             │  (CardView con logo + controles)
    │  [Logo]  Nombre  Subtítulo          │
    │  ─────────────────────────────────  │
    │  [🔍  Campo URL                  ]  │
    │  [▶ Navegar ]  [ 🕑 Historial ]     │
    │  [✕ Limpiar ]  [ ↻ Recargar  ]     │
    │  [ProgressBar]                      │
    ├─────────────────────────────────────┤
    │                                     │
    │            WebView                  │
    │                                     │
    └─────────────────────────────────────┘
-->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background"
    tools:context=".MainActivity">

    <!-- =========================================
         PANEL SUPERIOR — Card con controles
         ========================================= -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@color/md_primary"
        app:cardCornerRadius="0dp"
        app:cardElevation="8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="14dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

            <!-- Logo de la aplicación -->
            <ImageView
                android:id="@+id/iv_logo"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="@string/logo_description"
                android:src="@drawable/ic_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Nombre de la app -->
            <TextView
                android:id="@+id/tv_app_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.04"
                android:text="@string/app_name"
                android:textColor="#FFFFFF"
                android:textSize="19sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/iv_logo" />

            <!-- Subtítulo -->
            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:fontFamily="sans-serif"
                android:text="@string/app_subtitle"
                android:textColor="#B8CFFF"
                android:textSize="11sp"
                android:letterSpacing="0.03"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_app_name" />

            <!-- Separador -->
            <View
                android:id="@+id/divider_top"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:background="#3DFFFFFF"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_subtitle" />

            <!-- Campo de URL — TextInputLayout Material 3 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_url"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="@string/hint_url"
                app:boxBackgroundColor="#FFFFFF"
                app:boxStrokeColor="#D5E3FF"
                app:boxStrokeWidth="1.5dp"
                app:boxStrokeWidthFocused="2dp"
                app:hintTextColor="#1A3C6E"
                app:startIconDrawable="@android:drawable/ic_menu_search"
                app:startIconTint="#1A3C6E"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/divider_top">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_url"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:imeOptions="actionGo"
                    android:inputType="textUri"
                    android:maxLines="1"
                    android:textColor="#1A1C23"
                    android:textSize="13sp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- ── FILA 1 de botones: Navegar | Historial ── -->
            <LinearLayout
                android:id="@+id/layout_buttons_row1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/til_url">

                <!-- Botón Navegar (primario, relleno) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send"
                    style="@style/Widget.NavegadorAula.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="@string/btn_send"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:ellipsize="none"
                    android:singleLine="true"
                    app:backgroundTint="#FFFFFF"
                    android:textColor="@color/md_primary"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_media_play"
                    app:iconSize="15dp"
                    app:iconTint="@color/md_primary"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp" />

                <!-- Botón Historial (outlined) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_history"
                    style="@style/Widget.NavegadorAula.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="@string/btn_history"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:ellipsize="none"
                    android:singleLine="true"
                    android:textColor="#FFFFFF"
                    app:strokeColor="#FFFFFF"
                    app:strokeWidth="1.5dp"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_menu_recent_history"
                    app:iconSize="15dp"
                    app:iconTint="#FFFFFF"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:rippleColor="#33FFFFFF" />

            </LinearLayout>

            <!-- ── FILA 2 de botones: Limpiar | Recargar ── -->
            <LinearLayout
                android:id="@+id/layout_buttons_row2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_buttons_row1">

                <!-- Botón Limpiar (outlined secundario) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear"
                    style="@style/Widget.NavegadorAula.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:text="@string/btn_clear"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:ellipsize="none"
                    android:singleLine="true"
                    android:textColor="#B8CFFF"
                    app:strokeColor="#5578A8"
                    app:strokeWidth="1dp"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_menu_close_clear_cancel"
                    app:iconSize="14dp"
                    app:iconTint="#B8CFFF"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:rippleColor="#33FFFFFF" />

                <!-- Botón Recargar (texto) -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reload"
                    style="@style/Widget.NavegadorAula.Button.Text"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="@string/btn_reload"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:ellipsize="none"
                    android:singleLine="true"
                    android:textColor="#B8CFFF"
                    app:cornerRadius="10dp"
                    app:icon="@android:drawable/ic_popup_sync"
                    app:iconSize="14dp"
                    app:iconTint="#B8CFFF"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:rippleColor="#33FFFFFF" />

            </LinearLayout>

            <!-- Indicador de progreso — Material3 LinearProgressIndicator -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progress_bar"
                style="@style/Widget.NavegadorAula.LinearProgressIndicator"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:visibility="invisible"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layout_buttons_row2"
                app:trackColor="#3DFFFFFF"
                app:indicatorColor="#FFFFFF"
                app:trackCornerRadius="2dp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- =========================================
         WEBVIEW — Ocupa el resto de la pantalla
         ========================================= -->
    <WebView
        android:id="@+id/web_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/md_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_controls" />

    <!-- Overlay de estado vacío (visible cuando no hay URL cargada) -->
    <LinearLayout
        android:id="@+id/layout_empty_state"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="visible"
        android:background="@color/md_background"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/card_controls">

        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:src="@drawable/ic_logo"
            android:alpha="0.25"
            android:contentDescription="@string/logo_description" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:text="Ingresa una URL para comenzar"
            android:textColor="@color/md_on_surface_variant"
            android:textSize="16sp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:text="Solo se permiten sitios con https://"
            android:textColor="@color/md_outline"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
